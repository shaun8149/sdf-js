{
  "name": "atlas",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Atlas — LLM-native illustration platform. Built on sdf-js. Root package: tooling + CI orchestration.",
  "scripts": {
    "test": "node scripts/run-tests.mjs",
    "build:icons": "node sdf-js/scripts/bake-icon-library-v2.mjs",
    "test:smoke": "node scripts/run-tests.mjs smoke",
    "test:sanity": "node scripts/run-tests.mjs sanity",
    "test:world": "node scripts/run-tests.mjs world",
    "test:scene": "node scripts/run-tests.mjs scene",
    "test:generator": "node scripts/run-tests.mjs generator",
    "test:port-shader": "node scripts/run-tests.mjs port-shader",
    "test:regression": "echo 'Requires ANTHROPIC_API_KEY. Excluded from CI.' && node sdf-js/scripts/regression/lift-regression.mjs",
    "eval": "node sdf-js/scripts/eval-corpus.mjs",
    "eval:bake": "node sdf-js/scripts/eval-corpus.mjs --bake --key-file key.txt",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "serve": "cd sdf-js && python3 dev-server.py 8001",
    "prepare": "husky"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "SEE LICENSE IN LICENSE.md",
  "lint-staged": {
    "*.{js,mjs,cjs}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,yml,yaml}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.5.0",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.4"
  },
  "dependencies": {
    "@phosphor-icons/core": "^2.1.1",
    "flag-icons": "^7.2.3",
    "pdfjs-dist": "^6.0.227",
    "simple-icons": "^16.24.0"
  }
}
