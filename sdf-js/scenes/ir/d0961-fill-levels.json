  "script": [
    {
      "text": "欢迎。这是一套填充水平可视化模板,包含三档填充:80%、40%、20%,以及三个编号球体。",
      "station": 0,
      "kind": "station"
    },
    {
      "text": "第一组变体:四档递增,从20%升至90%,球体标注为①到④。",
      "station": 1,
      "kind": "station"
    },
    {
      "text": "第二页展示三个描述标签,聚焦中间球体DESCRIPTION 2,填充至60%。",
      "station": 2,
      "kind": "station"
    },
    {
      "text": "单球版本:填充级别50%,附长段占位文本,演示详细说明区的排版能力。",
      "station": 3,
      "kind": "station"
    },
    {
      "text": "满值示例:单个球体100%填充,副标题为占位符,无实质数据声明。",
      "station": 4,
      "kind": "station"
    },
    {
      "text": "进入五项对比场景。DESCRIPTION 4达到100%,其余四项依次排列,展示五球横向布局。",
      "station": 5,
      "kind": "station"
    },
    {
      "text": "三球梯度:DESCRIPTION 1为50%,DESCRIPTION 2满值100%,DESCRIPTION 3居中80%。",
      "station": 6,
      "kind": "station"
    },
    {
      "text": "另一组三球:THIS IS A为80%,PLACEHOLDER TEXT为60%,副标题球体为50%。",
      "station": 7,
      "kind": "station"
    },
    {
      "text": "空白模板页,仅标题与副标题占位符,无球体数据内容。",
      "station": 8,
      "kind": "station"
    },
    {
      "text": "第二张空白页,结构相同,副标题为待填充状态。",
      "station": 9,
      "kind": "station"
    },
    {
      "text": "四球模板回归:Description 2领先,填充50%,其余三项为占位标签。",
      "station": 10,
      "kind": "station"
    },
    {
      "text": "五球示例页,中文说明为模板页面,占位文本重复五次,实际内容待替换。",
      "station": 11,
      "kind": "station"
    },
    {
      "text": "单球高值突出:Description 1达到90%,演示峰值表现的视觉焦点。",
      "station": 12,
      "kind": "station"
    },
    {
      "text": "三项对等结构,每项标注DESCRIPTION TEXT,附相同占位说明,强调并列关系而非数据差异。",
      "station": 13,
      "kind": "station"
    },
    {
      "text": "四球满值页:所有球体显示100%,DESCRIPTION 1到4各配占位文本,展示满载状态下的信息密度。",
      "station": 14,
      "kind": "station"
    },
    {
      "text": "三项数值组合:80%、60%、70%,中文副标题提示为模板页,占位文本待替换。",
      "station": 15,
      "kind": "station"
    },
    {
      "text": "三档递增再现:从20%经40%至90%,编号①②③,模板结构清晰复现。",
      "station": 16,
      "kind": "station"
    },
    {
      "text": "轴刻度演示:填充级别从10%到100%,等间距数列为刻度标注,非实际数据,仅展示度量框架。",
      "station": 17,
      "kind": "station"
    },
    {
      "text": "无数据内容页,副标题占位符需替换为真实内容,模板结构保留完整。",
      "station": 18,
      "kind": "station"
    },
    {
      "text": "尾页标注2D SPHERES,标题为填充级别演示,模板页无实际数据内容,结构收尾。",
      "station": 19,
      "kind": "station"
    }
  ]
}
