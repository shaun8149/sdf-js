  "code2d": "```js\nimport {\n  circle, ellipse, rectangle, rounded_rectangle, polygon, triangle,\n  segment, arc, line,\n  union, intersection, difference, dilate, erode, shell,\n  render,\n} from '../../src/index.js';\n\n// \u2500\u2500 Palette \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\nconst SKY_TOP     = [138, 168, 195];\nconst SKY_BOTTOM  = [210, 200, 178];\nconst MIST        = [220, 215, 205];\nconst MTN_FAR     = [ 98, 115, 130];\nconst MTN_MID     = [120, 138, 115];\nconst MTN_NEAR    = [ 78,  98,  72];\nconst FIELD       = [168, 172,  98];\nconst GROUND      = [120, 118,  72];\nconst WALL_C      = [210, 195, 162];\nconst ROOF_C      = [ 88,  82,  68];\nconst ROOF_TILE   = [ 62,  58,  48];\nconst CHIMNEY_C   = [160, 148, 125];\nconst TREE_DARK   = [ 55,  72,  48];\nconst TREE_MID    = [ 72,  98,  58];\nconst SHADOW_C    = [ 50,  52,  45];\nconst OUTLINE     = [ 32,  28,  22];\nconst MIST2       = [218, 214, 208];\nconst WATER_C     = [148, 170, 185];\nconst PATH_C      = [175, 162, 128];\n\n// \u2500\u2500 Mountains (far, two layers) \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\nconst mtnFarL = polygon([\n  [-1.3, 0.10], [-1.05, 0.52], [-0.78, 0.28], [-0.55, 0.62], [-0.28, 0.30],\n  [-0.05, 0.44], [ 0.20, 0.15], [-1.3, 0.15],\n]);\nconst mtnFarR = polygon([\n  [ 0.10, 0.12], [ 0.38, 0.58], [ 0.62, 0.32], [ 0.85, 0.65],\n  [ 1.10, 0.38], [ 1.30, 0.48], [ 1.30, 0.12],\n]);\nconst mtnsFar = union(mtnFarL, mtnFarR);\n\n// mist veil over far mountains\nconst mistVeil = intersection(\n  rectangle([2.6, 0.08], [0, 0.24]),\n  union(mtnFarL, mtnFarR),\n);\n\n// \u2500\u2500 Mountains (nearer, greenish slopes) \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\nconst mtnMidL = polygon([\n  [-1.30, -0.10], [-1.10, 0.28], [-0.82, 0.05], [-0.60, 0.40],\n  [-0.35, 0.12], [-0.12, 0.32], [ 0.08, 0.05], [-1.30, 0.05],\n]);\nconst mtnMidR = polygon([\n  [ 0.05, 0.05], [ 0.25, 0.40], [ 0.50, 0.18], [ 0.78, 0.50],\n  [ 1.05, 0.22], [ 1.30, 0.35], [ 1.30, 0.05],\n]);\nconst mtnsMid = union(mtnMidL, mtnMidR);\n\n// \u2500\u2500 Near ridge / hillside \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\nconst ridgeNear = polygon([\n  [-1.30, -0.28], [-0.95, 0.04], [-0.68, -0.10], [-0.40, 0.10],\n  [-0.10, -0.08], [ 0.18, 0.06], [ 0.48, -0.12], [ 0.75, 0.02],\n  [ 1.05, -0.15], [ 1.30, -0.05], [ 1.30, -0.35], [-1.30, -0.35],\n]);\n\n// \u2500\u2500 Ground plane / terraced fields \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\nconst groundPlane = rectangle([2.6, 0.60], [0, -0.80]);\nconst fieldTerrace1 = intersection(\n  rectangle([2.6, 0.045], [0, -0.345]),\n  union(\n    rectangle([0.65, 0.045], [-0.55, -0.345]),\n    rectangle([0.50, 0.045], [ 0.45, -0.345]),\n  ),\n);\nconst fieldTerrace2 = intersection(\n  rectangle([2.6, 0.035], [0, -0.455]),\n  union(\n    rectangle([0.80, 0.035], [-0.30, -0.455]),\n    rectangle([0.35, 0.035], [ 0.80, -0.455]),\n  ),\n);\n\n// \u2500\u2500 Small stream / pond \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\nconst stream = ellipse(0.12, 0.03, [0.05, -0.48]);\nconst streamNarrow = segment([-0.28, -0.50], [0.00, -0.48], 0.012);\nconst water = union(stream, streamNarrow);\n\n// \u2500\u2500 Path winding from near base up to village \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\nconst path = union(\n  segment([ 0.10, -0.85], [ 0.05, -0.55], 0.018),\n  segment([ 0.05, -0.55], [-0.08, -0.42], 0.014),\n  segment([-0.08, -0.42], [-0.18, -0.30], 0.012),\n);\n\n// \u2500\u2500 Helper: simple alpine house \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\nfunction house(cx, cy, w, h, roofH, roofOverhang = 0.01) {\n  const wall   = rectangle([w, h], [cx, cy + h / 2]);\n  const roofW  = w + roofOverhang * 2;\n  const roof   = triangle(\n    [cx - roofW / 2, cy + h],\n    [cx + roofW / 2, cy + h],\n    [cx, cy + h + roofH],\n  );\n  const chimneyW = w * 0.12;\n  const chimneyH = roofH * 0.55;\n  const chimney  = rectangle(\n    [chimneyW, chimneyH],\n    [cx + w * 0.22, cy + h + roofH * 0.72],\n  );\n  const doorW = w * 0.22;\n  const doorH = h * 0.38;\n  const door  = rounded_rectangle(\n    [doorW, doorH],\n    [cx - w * 0.15, cy + doorH / 2],\n    doorW * 0.45,\n  );\n  const winW  = w * 0.18;\n  const winH  = h * 0.22;\n  const winL  = rectangle([winW, winH], [cx - w * 0.28, cy + h * 0.60]);\n  const winR  = rectangle([winW, winH], [cx + w * 0.28, cy + h * 0.60]);\n  const body  = union(wall, roof, chimney);\n  const cutout = union(door, winL, winR);\n  return { body, cutout, roof, chimney, wall };\n}\n\n// \u2500\u2500 Build village: cluster of 6 houses on the slope \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\nconst h1 = house(-0.62, -0.28, 0.18, 0.18, 0.10, 0.012);\nconst h2 = house(-0.38, -0.22, 0.16, 0.16, 0.09, 0.010);\nconst h3 = house(-0.14, -0.26, 0.20, 0.20, 0.11, 0.014);\nconst h4 = house( 0.16, -0.20, 0.15, 0.15, 0.08, 0.010);\nconst h5 = house( 0.40, -0.25, 0.17, 0.17, 0.10, 0.012);\nconst h6 = house(-0.50, -0.10, 0.13, 0.13, 0.08, 0.008); // upper cluster\n\nconst allWalls    = union(h1.wall, h2.wall, h3.wall, h4.wall, h5.wall, h6.wall);\nconst allRoofs    = union(h1.roof, h2.roof, h3.roof, h4.roof, h5.roof, h6.roof);\nconst allChimneys = union(h1.chimney, h2.chimney, h3.chimney, h4.chimney, h5.chimney, h6.chimney);\nconst allCutouts  = union(h1.cutout, h2.cutout, h3.cutout, h4.cutout, h5.cutout, h6.cutout);\n\nconst wallsFinal     = difference(allWalls, allCutouts);\nconst wallsOutline   = dilate(allWalls, 0.018);\nconst roofsOutline   = dilate(allRoofs, 0.014);\nconst roofRidge      = intersection(allRoofs, dilate(\n  union(\n    segment([-0.62, -0.10], [-0.62, -0.10 + 0.001], 0.002),\n    segment([-0.38, -0.06], [-0.38, -0.06 + 0.001], 0.002),\n  ), 0.002\n));\n\n// \u2500\u2500 Trees: conifers on the slopes \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\nfunction conifer(cx, cy, r, layers = 3) {\n  let tree = circle(0.001, [cx, cy]);\n  for (let i = 0; i < layers; i++) {\n    const ly  = cy + (r * 0.35) * i;\n    const lr  = r * (1 - i * 0.22);\n    const tier = triangle(\n      [cx - lr, ly],\n      [cx + lr, ly],\n      [cx, ly + r * 0.75],\n    );\n    tree = union(tree, tier);\n  }\n  // trunk\n  tree = union(tree, segment([cx, cy - r * 0.35], [cx, cy], r * 0.07));\n  return tree;\n}\n\nconst treePositions = [\n  [-1.05, -0.22, 0.12], [-0.92, -0.18, 0.10], [-0.80, -0.20, 0.11],\n  [ 0.62, -0.22, 0.11], [ 0.75, -0.18, 0.13], [ 0.90, -0.24, 0.10],\n  [ 1.05, -0.16, 0.12], [-0.72, -0.25, 0.09], [ 1.18, -0.20, 0.10],\n  [-0.28, -0.08, 0.09], [ 0.28, -0.08, 0.10], // upper slope trees\n];\n\nconst conifers = union(...treePositions.map(([x, y, r]) => conifer(x, y, r, 3)));\nconst conifersOutline = dilate(conifers, 0.014);\n\n// \u2500\u2500 Smoke wisps from chimneys \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\nconst smoke = union(\n  circle(0.018, [-0.62 + 0.22 * 0.22, -0.28 + 0.18 + 0.10 * 0.72 + 0.035]),\n  circle(0.014, [-0.14 + 0.20 * 0.22, -0.26 + 0.20 + 0.11 * 0.72 + 0.028]),\n  circle(0.012, [ 0.40 + 0.17 * 0.22, -0.25 + 0.17 + 0.10 * 0.72 + 0.022]),\n);\n\n// \u2500\u2500 Mist layer drifting through the valley \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\nconst mistBand = intersection(\n  ellipse(0.90, 0.055, [-0.15, -0.18]),\n  rectangle([2.0, 0.11], [-0.15, -0.18]),\n);\nconst mistBand2 = intersection(\n  ellipse(0.70, 0.04, [0.30, -0.32]),\n  rectangle([1.4, 0.08], [0.30, -0.32]),\n);\n\n// \u2500\u2500 Church / bell tower (central focal point) \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\nconst towerBase    = rectangle([0.095, 0.30], [-0.14, -0.12]);\nconst towerTop     = triangle(\n  [-0.14 - 0.065, -0.12 + 0.30],\n  [-0.14 + 0.065, -0.12 + 0.30],\n  [-0.14, -0.12 + 0.30 + 0.14],\n);\nconst towerWindow  = arc(0.025, Math.PI / 2, 0.006, [-0.14, -0.12 + 0.20]);\nconst towerBody    = union(towerBase, towerTop);\nconst towerOutline = dilate(towerBody, 0.020);\nconst crossV = segment([-0.14, -0.12 + 0.34], [-0.14, -0.12 + 0.30 + 0.14 - 0.005], 0.005);\nconst crossH = segment([-0.14 - 0.018, -0.12 + 0.36], [-0.14 + 0.018, -0.12 + 0.36], 0.005);\nconst towerCross = union(crossV, crossH);\n\n// \u2500\u2500 Assemble layers \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\nconst canvas = document.getElementById('c');\nconst ctx    = canvas.getContext('2d');\n\nrender.silhouette(ctx, [\n  // 1. far mountains\n  { sdf: mtnsFar,       color: MTN_FAR   },\n  // 2. mist over far mountains\n  { sdf: mistVeil,      color: MIST      },\n  // 3. mid mountains\n  { sdf: mtnsMid,       color: MTN_MID   },\n  // 4. near ridge\n  { sdf: ridgeNear,     color: MTN_NEAR  },\n  // 5. ground plane\n  { sdf: groundPlane,   color: GROUND    },\n  // 6. field terraces\n  { sdf: fieldTerrace1, color: FIELD     },\n  { sdf: fieldTerrace2, color: FIELD     },\n  // 7. stream / pond\n  { sdf: water,         color: WATER_C   },\n  // 8. path\n  { sdf: path,          color: PATH_C    },\n  // 9. tree outlines (drawn first as shadow)\n  { sdf: conifersOutline, color: SHADOW_C },\n  { sdf: conifers,        color: TREE_DARK },\n  // brighter conifer highlights\n  { sdf: erode(conifers, 0.018), color: TREE_MID },\n  // 10. valley mist\n  { sdf: mistBand,      color: MIST2     },\n  { sdf: mistBand2,     color: MIST2     },\n  // 11. house walls (outlines first)\n  { sdf: wallsOutline,  color: OUTLINE   },\n  { sdf: wallsFinal,    color: WALL_C    },\n  // 12. roofs\n  { sdf: roofsOutline,  color: OUTLINE   },\n  { sdf: allRoofs,      color: ROOF_C    },\n  { sdf: erode(allRoofs, 0.010), color: ROOF_TILE },\n  // 13. chimneys\n  { sdf: allChimneys,   color: CHIMNEY_C },\n  // 14. church tower\n  { sdf: towerOutline,  color: OUTLINE   },\n  { sdf: towerBody,     color: WALL_C    },\n  { sdf: towerCross,    color: OUTLINE   },\n  { sdf: towerWindow,   color: OUTLINE   },\n  // 15. smoke\n  { sdf: smoke,         color: MIST2     },\n], {\n  view: 1.3,\n  background: { top: SKY_TOP, bottom: SKY_BOTTOM },\n});\n```\n\n**Composition notes:**\n\n\u5c71\u95f4\u6751\u843d\u6309\u7ecf\u5178\u7684\"\u666f\u6df1\u53e0\u5c42\"\u65b9\u5f0f\u7ec4\u7ec7\u2014\u2014\u8fdc\u5c71 \u2192 \u4e2d\u5c71 \u2192 \u8fd1\u5761 \u2192 \u8c37\u5730 \u2192 \u6751\u843d\uff0c\u6bcf\u5c42\u4ee5\u989c\u8272\u63a8\u8fdc\uff08\u84dd\u7070\u2192\u7070\u7eff\u2192\u6df1\u7eff\uff09\uff0c\u8425\u9020\u51fa\u745e\u58eb/\u5fbd\u5dde\u5c71\u6751\u7684\u5927\u6c14\u900f\u89c6\u611f\u3002\u8fdc\u5c71\u4e0e\u4e2d\u5c71\u4e4b\u95f4\u63d2\u5165\u4e00\u9053\u6c34\u5e73\u8584\u96fe\uff08`intersection(ellipse, rectangle)`\uff09\uff0c\u6a21\u62df\u5c71\u8c37\u6668\u96fe\u6f02\u6d6e\u7684\u89c6\u89c9\u3002\n\n\u516d\u680b\u6c11\u5c45\u4f7f\u7528\u53c2\u6570\u5316 `house()` builder \u6279\u91cf\u751f\u6210\uff0c\u6bcf\u680b\u7531\u5899\u4f53\u3001\u4e09\u89d2\u5c4b\u9876\u3001\u70df\u56f1\u3001\u95e8\u7a97\u6784\u6210\uff0c\u95e8\u7a97\u4ee5 `difference` \u5207\u7a7a\u3002\u4e2d\u592e\u6559\u5802\u949f\u5854\u4f5c\u4e3a\u7126\u70b9\uff0c\u6bd4\u6c11\u5c45\u7a0d\u9ad8\uff0c\u9876\u90e8\u52a0\u5341\u5b57\u67b6\u4e0e\u5706\u5f27\u7a97\u3002`dilate`-outline idiom \u5206\u7ea7\u4f7f\u7528\uff1a\u4e3b\u4f53\u5efa\u7b51 0.018\uff0c\u5c4b\u9876 0.014\uff0c\u7ec6\u8282\u88c5\u9970 0.008\uff0c\u5f62\u6210\u89c6\u89c9\u5c42\u7ea7\u3002\n\n\u9488\u53f6\u6797\uff08`conifer()` builder\uff0c\u4e09\u5c42\u4e09\u89d2\u53e0\u52a0 + \u6811\u5e72 capsule\uff09\u5206\u5e03\u5728\u4e24\u4fa7\u5c71\u5761\uff0c\u4ee5\u6df1\u2192\u6d45\u4e24\u5c42\u6e32\u67d3\u51fa\u4fa7\u5149\u611f\u3002\u6eaa\u6d41\u4e0e\u68af\u7530\u6761\u5e26\u7528 `intersection(rect, plane)` \u88c1\u5207\uff0c\u4fdd\u6301\u5730\u5f62\u7684\u5c42\u6b21\u8f6e\u5ed3\u3002\u6574\u4f53\u8c03\u8272\u53c2\u8003\u4e86\u4e2d\u56fd\u5c71\u6c34\u7248\u753b\u7684\u9752\u7070\u7eff + \u6696\u767d\u7684\u649e\u8272\u903b\u8f91\uff0c\u80cc\u666f\u5929\u7a7a\u4ece\u51b7\u84dd\u6e10\u53d8\u4e3a\u6696\u7c73\uff0c\u6697\u793a\u6e05\u6668\u65f6\u5206\u3002",
