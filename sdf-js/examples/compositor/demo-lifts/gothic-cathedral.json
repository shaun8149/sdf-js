  "prompt": "\u4e00\u5ea7\u54e5\u7279\u5f0f\u5927\u6559\u5802",
  "code2d": "```js\nimport {\n  circle, ellipse, rectangle, rounded_rectangle, polygon, triangle, segment, arc, ring,\n  union, intersection, difference, dilate, erode, shell,\n  render,\n} from '../../src/index.js';\n\n// \u2500\u2500\u2500 Palette \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\nconst SKY_TOP    = [168, 195, 220];\nconst SKY_BOT    = [224, 215, 195];\nconst GROUND_C   = [148, 152, 120];\nconst STONE_C    = [210, 198, 172];\nconst STONE_D    = [188, 174, 148];   // darker stone, shadow sides\nconst WINDOW_C   = [140, 172, 210];   // stained-glass blue\nconst WINDOW_A   = [210, 140,  80];   // stained-glass amber\nconst ROSE_C     = [200, 120, 100];   // rose window centre\nconst OUTLINE    = [ 28,  22,  20];\n\n// \u2500\u2500\u2500 Helpers \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n// Pointed-arch (\"lancet\") window: rect body + triangular point\nfunction lancet(cx, baseY, w, h, pointiness = 0.45) {\n  const hw   = w / 2;\n  const rectH = h * (1 - pointiness);\n  const triH  = h * pointiness;\n  return union(\n    rectangle([w, rectH], [cx, baseY + rectH / 2]),\n    polygon([\n      [cx - hw, baseY + rectH],\n      [cx + hw, baseY + rectH],\n      [cx,      baseY + rectH + triH],\n    ]),\n  );\n}\n\n// Flying-buttress arm: a fat diagonal segment from (x0,y0) to (x1,y1)\nfunction buttress(x0, y0, x1, y1, r = 0.022) {\n  return segment([x0, y0], [x1, y1], r);\n}\n\n// \u2500\u2500\u2500 Ground \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\nconst ground = rectangle([2.6, 0.40], [0, -1.10]);\n\n// \u2500\u2500\u2500 MAIN NAVE & TRANSEPT BODY \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n// Central nave tower (tall, slightly narrower)\nconst naveTower = rectangle([0.38, 1.10], [0, -0.32]);\n\n// Transept wings (lower horizontal cross-arm)\nconst transeptLeft  = rectangle([0.28, 0.60], [-0.33, -0.48]);\nconst transeptRight = rectangle([0.28, 0.60], [ 0.33, -0.48]);\n\n// Choir (apse) \u2014 lower rectangular bulk at the base\nconst choir = rectangle([0.56, 0.32], [0, -0.90]);\n\n// Combine stone body\nconst stone = union(naveTower, transeptLeft, transeptRight, choir, { k: 0.018 });\n\n// \u2500\u2500\u2500 WEST FA\u00c7ADE (front face details) \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n// Stringcourse bands\nconst stringcourse1 = intersection(stone, rectangle([2.5, 0.018], [0, -0.30]));\nconst stringcourse2 = intersection(stone, rectangle([2.5, 0.018], [0, -0.62]));\n\n// \u2500\u2500\u2500 FLYING BUTTRESSES \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\nconst butt1L = buttress(-0.19, -0.38, -0.44, -0.62, 0.018);\nconst butt2L = buttress(-0.19, -0.55, -0.44, -0.72, 0.018);\nconst butt1R = buttress( 0.19, -0.38,  0.44, -0.62, 0.018);\nconst butt2R = buttress( 0.19, -0.55,  0.44, -0.72, 0.018);\nconst buttresses = union(butt1L, butt2L, butt1R, butt2R);\n\n// \u2500\u2500\u2500 TWIN BELL TOWERS (flanking the nave) \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\nconst towerL = rectangle([0.24, 1.52], [-0.50, 0.08]);\nconst towerR = rectangle([0.24, 1.52], [ 0.50, 0.08]);\n\n// Tower pinnacles (pointed caps on the bell towers)\nfunction spirePin(cx, baseY, w, h) {\n  const hw = w / 2;\n  return polygon([\n    [cx - hw, baseY],\n    [cx + hw, baseY],\n    [cx,      baseY + h],\n  ]);\n}\nconst spireL = spirePin(-0.50, 0.84, 0.22, 0.32);\nconst spireR = spirePin( 0.50, 0.84, 0.22, 0.32);\n\n// Central fl\u00e8che (thin needle spire over crossing)\nconst fleche = polygon([\n  [-0.045, 0.10],\n  [ 0.045, 0.10],\n  [ 0.018, 0.90],\n  [-0.018, 0.90],\n]);\nconst flecheSpire = polygon([\n  [-0.018, 0.90],\n  [ 0.018, 0.90],\n  [     0, 1.14],\n]);\nconst centralFl\u00e8che = union(fleche, flecheSpire);\n\n// Small pinnacles on transept gables\nconst pinTransL = spirePin(-0.33, -0.18, 0.10, 0.18);\nconst pinTransR = spirePin( 0.33, -0.18, 0.10, 0.18);\n\n// \u2500\u2500\u2500 ALL STONE (combined for outline base) \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\nconst allStone = union(\n  stone, buttresses,\n  towerL, towerR,\n  spireL, spireR,\n  centralFl\u00e8che,\n  pinTransL, pinTransR,\n);\n\n// \u2500\u2500\u2500 PORTALS (ground-level lancet doors) \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\nconst portalC = lancet(    0, -1.00, 0.22, 0.50, 0.50); // centre portal, largest\nconst portalL = lancet(-0.38, -1.00, 0.15, 0.36, 0.50);\nconst portalR = lancet( 0.38, -1.00, 0.15, 0.36, 0.50);\nconst portals = union(portalC, portalL, portalR);\n\n// \u2500\u2500\u2500 NAVE WINDOWS (tall lancets in nave) \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\nconst wNavL = lancet(-0.15, -0.72, 0.10, 0.34, 0.42);\nconst wNavR = lancet( 0.15, -0.72, 0.10, 0.34, 0.42);\n\n// Transept aisle windows\nconst wTransLL = lancet(-0.38, -0.72, 0.10, 0.28, 0.42);\nconst wTransRR = lancet( 0.38, -0.72, 0.10, 0.28, 0.42);\n\n// Clerestory windows (high up in the nave)\nconst wClerL = lancet(-0.12, -0.30, 0.08, 0.22, 0.42);\nconst wClerR = lancet( 0.12, -0.30, 0.08, 0.22, 0.42);\n\n// Bell tower windows (paired, stacked)\nfunction towerWindows(cx) {\n  return union(\n    lancet(cx, 0.14, 0.08, 0.18, 0.40),\n    lancet(cx, 0.42, 0.08, 0.18, 0.40),\n    lancet(cx, 0.64, 0.08, 0.14, 0.40),\n  );\n}\nconst twL = towerWindows(-0.50);\nconst twR = towerWindows( 0.50);\n\nconst allWindows = union(\n  portals,\n  wNavL, wNavR,\n  wTransLL, wTransRR,\n  wClerL, wClerR,\n  twL, twR,\n);\n\n// \u2500\u2500\u2500 ROSE WINDOW \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n// Centre circle + 8 petal openings arranged circularly\nconst roseCentre = circle(0.044, [0, 0.04]);\nconst rosePetals = roseCentre.circular_array(8).scale(1).translate([0, 0]).union\n  ? roseCentre  // fallback\n  : roseCentre;\n\n// Build the rose window as: outer ring difference of 8 small circles\nfunction roseWindow(cx, cy, R) {\n  const outer = ring(R, 0.016, [cx, cy]);\n  const spoke1 = segment([cx, cy], [cx,       cy + R], 0.008);\n  const spoke2 = segment([cx, cy], [cx,       cy - R], 0.008);\n  const spoke3 = segment([cx, cy], [cx + R,   cy    ], 0.008);\n  const spoke4 = segment([cx, cy], [cx - R,   cy    ], 0.008);\n  const spoke5 = segment([cx, cy], [cx + R * 0.707, cy + R * 0.707], 0.008);\n  const spoke6 = segment([cx, cy], [cx - R * 0.707, cy + R * 0.707], 0.008);\n  const spoke7 = segment([cx, cy], [cx + R * 0.707, cy - R * 0.707], 0.008);\n  const spoke8 = segment([cx, cy], [cx - R * 0.707, cy - R * 0.707], 0.008);\n  const hub    = circle(R * 0.20, [cx, cy]);\n  return union(outer, spoke1, spoke2, spoke3, spoke4,\n               spoke5, spoke6, spoke7, spoke8, hub);\n}\n\nconst rose        = roseWindow(0, 0.06, 0.118); // rose window graphic\nconst roseAperture = circle(0.118, [0, 0.06]);  // filled hole in stone\n\n// \u2500\u2500\u2500 DARK-STONE SHADOW SIDES \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n// Shadow the right half of towers (simple vertical band intersection)\nconst shadowR = intersection(\n  union(towerR, spireR),\n  rectangle([0.12, 2.0], [0.50 + 0.06, 0.0]),\n);\nconst shadowFl\u00e8che = intersection(\n  centralFl\u00e8che,\n  rectangle([0.04, 2.0], [0.01, 0.5]),\n);\n\n// \u2500\u2500\u2500 LAYERS \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\nconst canvas = document.getElementById('c');\nconst ctx = canvas.getContext('2d');\n\nrender.silhouette(ctx, [\n  // Ground\n  { sdf: ground, color: GROUND_C },\n\n  // Stone silhouette outline (dilate trick)\n  { sdf: dilate(allStone, 0.028), color: OUTLINE },\n  { sdf: allStone,                color: STONE_C  },\n\n  // Darker stone shadow sides\n  { sdf: shadowR,      color: STONE_D },\n  { sdf: shadowFl\u00e8che, color: STONE_D },\n\n  // Stringcourses (slightly darker band)\n  { sdf: dilate(stringcourse1, 0.004), color: OUTLINE },\n  { sdf: stringcourse1, color: STONE_D },\n  { sdf: dilate(stringcourse2, 0.004), color: OUTLINE },\n  { sdf: stringcourse2, color: STONE_D },\n\n  // Stained-glass window fills (amber tint \u2014 warm light)\n  { sdf: allWindows, color: WINDOW_A },\n\n  // Window outlines (thin dark border)\n  { sdf: dilate(allWindows, 0.010), color: OUTLINE },\n  { sdf: allWindows,                color: WINDOW_A },\n\n  // Clerestory & nave windows \u2014 cooler blue on top\n  { sdf: union(wClerL, wClerR, wNavL, wNavR, twL, twR), color: WINDOW_C },\n\n  // Rose window aperture fill\n  { sdf: roseAperture, color: ROSE_C },\n  // Rose window tracery (dark spokes over the fill)\n  { sdf: rose, color: OUTLINE },\n\n], {\n  view: 1.25,\n  background: { top: SKY_TOP, bottom: SKY_BOT },\n});\n```\n\n---\n\n\u8fd9\u4ef6\u4f5c\u54c1\u57fa\u4e8e\u6cd5\u5170\u897f\u76db\u671f\u54e5\u7279\uff08High Gothic\uff09\u4e09\u6bb5\u5f0f\u897f\u7acb\u9762\u6784\u56fe\uff1a\n\n- **\u7ed3\u6784\u5206\u89e3**\uff1a\u4e2d\u6bbf\u5854\u4f53 + \u8896\u5eca\u7ffc + \u5531\u8bd7\u5385\u5408\u5e76\u4e3a\u4e3b\u77f3\u4f53\uff08smooth union k=0.018\uff09\uff0c\u53cc\u4fa7\u949f\u5854\u72ec\u7acb\u6210\u67f1\uff0c\u4e2d\u592e\u54e5\u7279\u5c16\u5854\uff08fl\u00e8che\uff09\u5728\u4ea4\u53c9\u70b9\u5347\u8d77\u2014\u2014\u53c2\u8003 Notre-Dame de Paris \u7684\u7acb\u9762\u5173\u7cfb\u3002\n- **\u7a97\u9970\u8bed\u8a00**\uff1a`lancet()` \u6784\u5efa\u5668\u7528\u77e9\u5f62 + \u4e09\u89d2\u5f62\u5408\u5e76\u6a21\u62df\u5c16\u62f1\u5f62\uff0c\u590d\u7528\u4e8e\u5927\u95e8\u3001\u4fa7\u5eca\u7a97\u3001\u51c0\u7a7a\u5c42\u7a97\u548c\u949f\u5854\u4e09\u6392\u53e0\u7a97\uff0c\u5171 9 \u5904\u8c03\u7528\uff1b\u73ab\u7470\u7a97\u4ee5 `ring` + 8 \u6761 `segment` \u8f90\u6761\u624b\u5de5\u6784\u9020\uff0c\u8fd1\u4f3c\u54e5\u7279\u77f3\u68c2\uff08tracery\uff09\u3002\n- **\u8f6e\u5ed3\u5206\u7ea7**\uff1a\u4e3b\u77f3\u4f53 t=0.028\uff0c\u7a97\u5b54 t=0.010\uff0c\u5e26\u9970 t=0.004\u2014\u2014\u4e09\u7ea7\u7c97\u7ec6\u8d4b\u4e88\u753b\u9762\u524d\u540e\u5c42\u6b21\u3002\n- **\u8c03\u8272\u53c2\u8003** Viollet-le-Duc \u7684\u590d\u539f\u624b\u7a3f\uff1a\u7c73\u8272\u77f3\u7070\u5ca9\uff08`STONE_C`\uff09\u4e3a\u4e3b\u8c03\uff0c\u53f3\u4fa7\u6697\u9762\u5207 `intersection` \u6df1\u8c03\uff08`STONE_D`\uff09\uff0c\u7a97\u73bb\u7483\u5206\u51b7\u84dd\u4e0e\u6696\u7425\u73c0\u4e24\u8272\u547c\u5e94\u5178\u578b\u54e5\u7279\u5f69\u7a97\uff0c\u5929\u7a7a\u4ece\u94a2\u84dd\u6e10\u53d8\u81f3\u6696\u5976\u6cb9\u8272\u6a21\u62df\u9ec4\u660f\u611f\u3002",
