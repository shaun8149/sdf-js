  "prompt": "一座哥特式大教堂",
  "code2d": "```js\nimport {\n  circle, ellipse, rectangle, rounded_rectangle, polygon, triangle, segment, arc, ring,\n  union, intersection, difference, dilate, erode, shell,\n  render,\n} from '../../src/index.js';\n\n// ─── Palette ───────────────────────────────────────────────────────────────\nconst SKY_TOP    = [168, 195, 220];\nconst SKY_BOT    = [224, 215, 195];\nconst GROUND_C   = [148, 152, 120];\nconst STONE_C    = [210, 198, 172];\nconst STONE_D    = [188, 174, 148];   // darker stone, shadow sides\nconst WINDOW_C   = [140, 172, 210];   // stained-glass blue\nconst WINDOW_A   = [210, 140,  80];   // stained-glass amber\nconst ROSE_C     = [200, 120, 100];   // rose window centre\nconst OUTLINE    = [ 28,  22,  20];\n\n// ─── Helpers ────────────────────────────────────────────────────────────────\n// Pointed-arch (\"lancet\") window: rect body + triangular point\nfunction lancet(cx, baseY, w, h, pointiness = 0.45) {\n  const hw   = w / 2;\n  const rectH = h * (1 - pointiness);\n  const triH  = h * pointiness;\n  return union(\n    rectangle([w, rectH], [cx, baseY + rectH / 2]),\n    polygon([\n      [cx - hw, baseY + rectH],\n      [cx + hw, baseY + rectH],\n      [cx,      baseY + rectH + triH],\n    ]),\n  );\n}\n\n// Flying-buttress arm: a fat diagonal segment from (x0,y0) to (x1,y1)\nfunction buttress(x0, y0, x1, y1, r = 0.022) {\n  return segment([x0, y0], [x1, y1], r);\n}\n\n// ─── Ground ─────────────────────────────────────────────────────────────────\nconst ground = rectangle([2.6, 0.40], [0, -1.10]);\n\n// ─── MAIN NAVE & TRANSEPT BODY ───────────────────────────────────────────────\n// Central nave tower (tall, slightly narrower)\nconst naveTower = rectangle([0.38, 1.10], [0, -0.32]);\n\n// Transept wings (lower horizontal cross-arm)\nconst transeptLeft  = rectangle([0.28, 0.60], [-0.33, -0.48]);\nconst transeptRight = rectangle([0.28, 0.60], [ 0.33, -0.48]);\n\n// Choir (apse) — lower rectangular bulk at the base\nconst choir = rectangle([0.56, 0.32], [0, -0.90]);\n\n// Combine stone body\nconst stone = union(naveTower, transeptLeft, transeptRight, choir, { k: 0.018 });\n\n// ─── WEST FAÇADE (front face details) ───────────────────────────────────────\n// Stringcourse bands\nconst stringcourse1 = intersection(stone, rectangle([2.5, 0.018], [0, -0.30]));\nconst stringcourse2 = intersection(stone, rectangle([2.5, 0.018], [0, -0.62]));\n\n// ─── FLYING BUTTRESSES ──────────────────────────────────────────────────────\nconst butt1L = buttress(-0.19, -0.38, -0.44, -0.62, 0.018);\nconst butt2L = buttress(-0.19, -0.55, -0.44, -0.72, 0.018);\nconst butt1R = buttress( 0.19, -0.38,  0.44, -0.62, 0.018);\nconst butt2R = buttress( 0.19, -0.55,  0.44, -0.72, 0.018);\nconst buttresses = union(butt1L, butt2L, butt1R, butt2R);\n\n// ─── TWIN BELL TOWERS (flanking the nave) ───────────────────────────────────\nconst towerL = rectangle([0.24, 1.52], [-0.50, 0.08]);\nconst towerR = rectangle([0.24, 1.52], [ 0.50, 0.08]);\n\n// Tower pinnacles (pointed caps on the bell towers)\nfunction spirePin(cx, baseY, w, h) {\n  const hw = w / 2;\n  return polygon([\n    [cx - hw, baseY],\n    [cx + hw, baseY],\n    [cx,      baseY + h],\n  ]);\n}\nconst spireL = spirePin(-0.50, 0.84, 0.22, 0.32);\nconst spireR = spirePin( 0.50, 0.84, 0.22, 0.32);\n\n// Central flèche (thin needle spire over crossing)\nconst fleche = polygon([\n  [-0.045, 0.10],\n  [ 0.045, 0.10],\n  [ 0.018, 0.90],\n  [-0.018, 0.90],\n]);\nconst flecheSpire = polygon([\n  [-0.018, 0.90],\n  [ 0.018, 0.90],\n  [     0, 1.14],\n]);\nconst centralFlèche = union(fleche, flecheSpire);\n\n// Small pinnacles on transept gables\nconst pinTransL = spirePin(-0.33, -0.18, 0.10, 0.18);\nconst pinTransR = spirePin( 0.33, -0.18, 0.10, 0.18);\n\n// ─── ALL STONE (combined for outline base) ──────────────────────────────────\nconst allStone = union(\n  stone, buttresses,\n  towerL, towerR,\n  spireL, spireR,\n  centralFlèche,\n  pinTransL, pinTransR,\n);\n\n// ─── PORTALS (ground-level lancet doors) ────────────────────────────────────\nconst portalC = lancet(    0, -1.00, 0.22, 0.50, 0.50); // centre portal, largest\nconst portalL = lancet(-0.38, -1.00, 0.15, 0.36, 0.50);\nconst portalR = lancet( 0.38, -1.00, 0.15, 0.36, 0.50);\nconst portals = union(portalC, portalL, portalR);\n\n// ─── NAVE WINDOWS (tall lancets in nave) ────────────────────────────────────\nconst wNavL = lancet(-0.15, -0.72, 0.10, 0.34, 0.42);\nconst wNavR = lancet( 0.15, -0.72, 0.10, 0.34, 0.42);\n\n// Transept aisle windows\nconst wTransLL = lancet(-0.38, -0.72, 0.10, 0.28, 0.42);\nconst wTransRR = lancet( 0.38, -0.72, 0.10, 0.28, 0.42);\n\n// Clerestory windows (high up in the nave)\nconst wClerL = lancet(-0.12, -0.30, 0.08, 0.22, 0.42);\nconst wClerR = lancet( 0.12, -0.30, 0.08, 0.22, 0.42);\n\n// Bell tower windows (paired, stacked)\nfunction towerWindows(cx) {\n  return union(\n    lancet(cx, 0.14, 0.08, 0.18, 0.40),\n    lancet(cx, 0.42, 0.08, 0.18, 0.40),\n    lancet(cx, 0.64, 0.08, 0.14, 0.40),\n  );\n}\nconst twL = towerWindows(-0.50);\nconst twR = towerWindows( 0.50);\n\nconst allWindows = union(\n  portals,\n  wNavL, wNavR,\n  wTransLL, wTransRR,\n  wClerL, wClerR,\n  twL, twR,\n);\n\n// ─── ROSE WINDOW ────────────────────────────────────────────────────────────\n// Centre circle + 8 petal openings arranged circularly\nconst roseCentre = circle(0.044, [0, 0.04]);\nconst rosePetals = roseCentre.circular_array(8).scale(1).translate([0, 0]).union\n  ? roseCentre  // fallback\n  : roseCentre;\n\n// Build the rose window as: outer ring difference of 8 small circles\nfunction roseWindow(cx, cy, R) {\n  const outer = ring(R, 0.016, [cx, cy]);\n  const spoke1 = segment([cx, cy], [cx,       cy + R], 0.008);\n  const spoke2 = segment([cx, cy], [cx,       cy - R], 0.008);\n  const spoke3 = segment([cx, cy], [cx + R,   cy    ], 0.008);\n  const spoke4 = segment([cx, cy], [cx - R,   cy    ], 0.008);\n  const spoke5 = segment([cx, cy], [cx + R * 0.707, cy + R * 0.707], 0.008);\n  const spoke6 = segment([cx, cy], [cx - R * 0.707, cy + R * 0.707], 0.008);\n  const spoke7 = segment([cx, cy], [cx + R * 0.707, cy - R * 0.707], 0.008);\n  const spoke8 = segment([cx, cy], [cx - R * 0.707, cy - R * 0.707], 0.008);\n  const hub    = circle(R * 0.20, [cx, cy]);\n  return union(outer, spoke1, spoke2, spoke3, spoke4,\n               spoke5, spoke6, spoke7, spoke8, hub);\n}\n\nconst rose        = roseWindow(0, 0.06, 0.118); // rose window graphic\nconst roseAperture = circle(0.118, [0, 0.06]);  // filled hole in stone\n\n// ─── DARK-STONE SHADOW SIDES ─────────────────────────────────────────────────\n// Shadow the right half of towers (simple vertical band intersection)\nconst shadowR = intersection(\n  union(towerR, spireR),\n  rectangle([0.12, 2.0], [0.50 + 0.06, 0.0]),\n);\nconst shadowFlèche = intersection(\n  centralFlèche,\n  rectangle([0.04, 2.0], [0.01, 0.5]),\n);\n\n// ─── LAYERS ─────────────────────────────────────────────────────────────────\nconst canvas = document.getElementById('c');\nconst ctx = canvas.getContext('2d');\n\nrender.silhouette(ctx, [\n  // Ground\n  { sdf: ground, color: GROUND_C },\n\n  // Stone silhouette outline (dilate trick)\n  { sdf: dilate(allStone, 0.028), color: OUTLINE },\n  { sdf: allStone,                color: STONE_C  },\n\n  // Darker stone shadow sides\n  { sdf: shadowR,      color: STONE_D },\n  { sdf: shadowFlèche, color: STONE_D },\n\n  // Stringcourses (slightly darker band)\n  { sdf: dilate(stringcourse1, 0.004), color: OUTLINE },\n  { sdf: stringcourse1, color: STONE_D },\n  { sdf: dilate(stringcourse2, 0.004), color: OUTLINE },\n  { sdf: stringcourse2, color: STONE_D },\n\n  // Stained-glass window fills (amber tint — warm light)\n  { sdf: allWindows, color: WINDOW_A },\n\n  // Window outlines (thin dark border)\n  { sdf: dilate(allWindows, 0.010), color: OUTLINE },\n  { sdf: allWindows,                color: WINDOW_A },\n\n  // Clerestory & nave windows — cooler blue on top\n  { sdf: union(wClerL, wClerR, wNavL, wNavR, twL, twR), color: WINDOW_C },\n\n  // Rose window aperture fill\n  { sdf: roseAperture, color: ROSE_C },\n  // Rose window tracery (dark spokes over the fill)\n  { sdf: rose, color: OUTLINE },\n\n], {\n  view: 1.25,\n  background: { top: SKY_TOP, bottom: SKY_BOT },\n});\n```\n\n---\n\n这件作品基于法兰西盛期哥特（High Gothic）三段式西立面构图：\n\n- **结构分解**：中殿塔体 + 袖廊翼 + 唱诗厅合并为主石体（smooth union k=0.018），双侧钟塔独立成柱，中央哥特尖塔（flèche）在交叉点升起——参考 Notre-Dame de Paris 的立面关系。\n- **窗饰语言**：`lancet()` 构建器用矩形 + 三角形合并模拟尖拱形，复用于大门、侧廊窗、净空层窗和钟塔三排叠窗，共 9 处调用；玫瑰窗以 `ring` + 8 条 `segment` 辐条手工构造，近似哥特石棂（tracery）。\n- **轮廓分级**：主石体 t=0.028，窗孔 t=0.010，带饰 t=0.004——三级粗细赋予画面前后层次。\n- **调色参考** Viollet-le-Duc 的复原手稿：米色石灰岩（`STONE_C`）为主调，右侧暗面切 `intersection` 深调（`STONE_D`），窗玻璃分冷蓝与暖琥珀两色呼应典型哥特彩窗，天空从钢蓝渐变至暖奶油色模拟黄昏感。",
