{
  "v": 1,
  "name": "Coastal village at sunrise (3D bird traffic + camera dolly)",
  "subjects": [
    {
      "id": "flock-east",
      "type": "rep",
      "args": { "period": [12, 0, 0] },
      "region": "birds",
      "transform": { "translate": [0, 0, 0] },
      "animation": [
        {
          "channel": "transform.translate.x",
          "value": { "kind": "time", "form": "linear", "coef": 3.0 }
        }
      ],
      "source": {
        "id": "bird-e",
        "type": "union",
        "transform": { "translate": [0, 7, -3] },
        "animation": [{ "channel": "transform.translate.y", "expr": "7 + 0.25 * cos(t * 3.5)" }],
        "children": [
          {
            "id": "bird-e-body",
            "type": "capsule",
            "args": { "a": [-0.2, 0, 0], "b": [0.2, 0, 0], "radius": 0.05 }
          },
          {
            "id": "bird-e-wings",
            "type": "capsule",
            "args": { "a": [0, 0, -0.28], "b": [0, 0, 0.28], "radius": 0.05 }
          }
        ]
      }
    },
    {
      "id": "flock-west",
      "type": "rep",
      "args": { "period": [14, 0, 0] },
      "region": "birds",
      "transform": { "translate": [0, 0, 0] },
      "animation": [
        {
          "channel": "transform.translate.x",
          "value": { "kind": "time", "form": "linear", "coef": -2.2 }
        }
      ],
      "source": {
        "id": "bird-w",
        "type": "union",
        "transform": { "translate": [0, 9, -6] },
        "animation": [{ "channel": "transform.translate.y", "expr": "9 + 0.2 * cos(t * 4)" }],
        "children": [
          {
            "id": "bird-w-body",
            "type": "capsule",
            "args": { "a": [-0.18, 0, 0], "b": [0.18, 0, 0], "radius": 0.04 }
          },
          {
            "id": "bird-w-wings",
            "type": "capsule",
            "args": { "a": [0, 0, -0.25], "b": [0, 0, 0.25], "radius": 0.04 }
          }
        ]
      }
    },
    {
      "id": "flock-inland",
      "type": "rep",
      "args": { "period": [0, 0, 13] },
      "region": "birds",
      "transform": { "translate": [0, 0, 0] },
      "animation": [
        {
          "channel": "transform.translate.z",
          "value": { "kind": "time", "form": "linear", "coef": 1.8 }
        }
