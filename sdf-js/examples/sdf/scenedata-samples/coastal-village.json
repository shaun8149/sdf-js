  "ground": { "y": -1.5, "region": "ground" },
  "defaults": {
    "camera": {
      "yaw": 0,
      "pitch": 0.1,
      "distance": 25,
      "focal": 1.5,
      "targetX": 0,
      "targetY": 1,
      "targetZ": 0,
      "animation": [{ "channel": "targetZ", "expr": "0.25 * t" }]
