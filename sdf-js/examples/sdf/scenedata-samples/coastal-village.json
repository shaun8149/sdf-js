      "source": {
        "id": "bird-i",
        "type": "union",
        "transform": { "translate": [6, 5, 0] },
        "animation": [{ "channel": "transform.translate.y", "expr": "5 + 0.18 * cos(t * 3)" }],
        "children": [
          {
            "id": "bird-i-body",
            "type": "capsule",
            "args": { "a": [0, 0, -0.2], "b": [0, 0, 0.2], "radius": 0.05 }
          },
          {
            "id": "bird-i-wings",
            "type": "capsule",
            "args": { "a": [-0.28, 0, 0], "b": [0.28, 0, 0], "radius": 0.05 }
          }
        ]
      }
    },
    {
      "id": "lighthouse",
      "type": "union",
      "region": "tower",
      "children": [
        {
          "id": "lighthouse-base",
          "type": "cylinder",
          "args": { "radius": 1.2, "height": 4 },
          "transform": { "translate": [-8, 1, -2] }
        },
        {
          "id": "lighthouse-top",
          "type": "cone",
          "args": { "height": 1.5, "baseRadius": 1.4 },
          "transform": { "translate": [-8, 4, -2] }
